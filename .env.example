# LLM Provider (OpenAI-compatible)
LLM_API_KEY=your_minimax_api_key_here
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-M2.7

# Web Search
TAVILY_API_KEY=your_tavily_api_key_here

# Persistent storage — set these on Render to survive redeploys
# Get from console.upstash.com → your database → REST API tab
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your_token_here

# App settings (optional)
SCORE_THRESHOLD=70
LOG_LEVEL=INFO

# Production: comma-separated list of allowed frontend origins
# e.g. https://your-app.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
